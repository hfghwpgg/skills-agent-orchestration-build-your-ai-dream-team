{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Project Pulse Dashboard",
      "type": "debugpy",
      "request": "launch",
      "python": "python3",
      "module": "http.server",
      "args": ["5500"],
      "cwd": "${workspaceFolder}/app",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Serving HTTP on .* port ([0-9]+)",
        "uriFormat": "http://localhost:%s/index.html",
        "action": "openExternally"
      }
    }
  ]
}
